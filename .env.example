# =============================================================================
# PEDIACORE — Environment template
# =============================================================================
# For production: copy to .env and fill in all CHANGE_ME values.
# NEVER commit .env to version control.
#
# Generate SECRET_KEY:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
# =============================================================================

# Django
SECRET_KEY=CHANGE_ME_use_python_c_import_secrets_secrets_token_urlsafe_50
DJANGO_SETTINGS_MODULE=config.settings.production
ALLOWED_HOSTS=estefipediatra.com,www.estefipediatra.com

# Database (PostgreSQL)
DB_NAME=pediacore
DB_USER=pediacore_user
DB_PASSWORD=CHANGE_ME_strong_password_here
DB_HOST=postgres
DB_PORT=5432

# CORS
CORS_ALLOWED_ORIGINS=https://estefipediatra.com,https://www.estefipediatra.com

# Cloudinary (file uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Resend (transactional email)
RESEND_API_KEY=
DEFAULT_FROM_EMAIL=Dra. Estefanía <no-reply@estefipediatra.com>

# Sentry (error monitoring — leave blank to disable)
SENTRY_DSN=

# MercadoPago
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_PUBLIC_KEY=
